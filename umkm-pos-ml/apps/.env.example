DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — pakai DB yang sama dengan Laravel (read-only access)
DB_NAME=umkm_pos_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Keamanan: token yang sama di .env Laravel (ANALYTICS_TOKEN)
ANALYTICS_TOKEN=your-secret-analytics-token

# Laravel backend URL (untuk kirim notifikasi balik jika perlu)
LARAVEL_URL=http://127.0.0.1:8000

# Storage untuk PDF
PDF_STORAGE=local        # local | s3
PDF_LOCAL_DIR=storage/reports

# S3 (opsional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-southeast-1
